Step 6: Ranking
===============================
--1.Which 5 products generate the highest revenue

Select Top 5
c.product_name,
sum(f.sales_amount) as Total_revenue
From gold.fact_sales f
left Join gold.dim_products c
	on f.product_key = c.prd_key
Group by c.product_name 
order by Total_revenue desc

--2.what are the 5 worst-performing products in terms of sales

Select Top 5
c.product_name,
sum(f.sales_amount) as Total_revenue
From gold.fact_sales f
left Join gold.dim_products c
	on f.product_key = c.prd_key
Group by c.product_name 
order by Total_revenue asc

--3.Which 5 subcategory products generate the highest revenue

Select Top 5
c.subcategory,
sum(f.sales_amount) as Total_revenue
From gold.fact_sales f
left Join gold.dim_products c
	on f.product_key = c.prd_key
Group by c.subcategory 
order by Total_revenue desc

--4.what are the 5 worst-performing subcategory in terms of sales

Select Top 5
c.subcategory,
sum(f.sales_amount) as Total_revenue
From gold.fact_sales f
left Join gold.dim_products c
	on f.product_key = c.prd_key
Group by c.subcategory 
order by Total_revenue asc

---5. Using window functions
Select * From(
Select
c.product_name,
sum(f.sales_amount) as Total_revenue,
row_number() over(order by sum(f.sales_amount) desc) as Rank
From gold.fact_sales f
left Join gold.dim_products c
	on f.product_key = c.prd_key
Group by product_name
)t
where Rank <= 5

--Find the Top-10 customers who have generated the highest revenue and 3 customers with the fewest orders placed


Select 
* 
From(
	Select
		C.Customer_key,
		c.first_name,
		c.last_name,
	sum(f.sales_amount) as Total_revenue,
	row_number() over(order by sum(f.sales_amount) desc) as Rank
	From gold.fact_sales f
	left Join gold.dim_customers c
		on f.Customer_key = c.Customer_key
	Group by 
		C.Customer_key,
		c.first_name,
		c.last_name
)t
where Rank <= 10

--The 3 customers with the fewest orders placed

	Select Top 3
		C.Customer_key,
		c.first_name,
		c.last_name,
	count(Distinct order_number) as Total_order
	From gold.fact_sales f
	left Join gold.dim_customers c
		on f.Customer_key = c.Customer_key
	Group by 
		C.Customer_key,
		c.first_name,
		c.last_name
	order by Total_order


