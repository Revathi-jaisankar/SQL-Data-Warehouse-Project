/*segment Products into cost ranges 
and count how many products fall into each segment.*/

WITH segment_analysis AS(
select
Product_name,
cost,
CASE 
	WHEN cost < 100 THEN 'BELOW 100'
	WHEN COST BETWEEN 100 AND 500 THEN '100-500'
	WHEN COST BETWEEN 500 AND 1000 THEN '500-1000'
	ELSE 'ABOVE 1000'
END Cost_range
from gold.dim_products 
)
Select
	Cost_range,
	count(*) as Total_count
From segment_analysis
Group by Cost_range
order by Total_count desc

/*
	Group customer into three segments based on thier spending behavior :
	-VIP: Customers with at least 12 months of history and spending more than euro 5000.
	-Regular: Customer With atlest 12 months  of history but spending 5000 or less.
	-New: Customer with a lifespan less than 12 months.
and Find the total number of customer by each group 
*/
with customer_segment as (
Select
	c.customer_key as customer_key,
	sum(f.sales_amount) as Customer_spending,
	min(order_date) as First_order,
	min(order_date) as last_order,
	DATEDIFF(month, min(order_date), min(order_date)) as Lifespan
From gold.fact_sales f
left join gold.dim_Customers c
	on f.Customer_key = c.Customer_key
Group by c.customer_key
)
select 
	Lifespan_segment,
	count(customer_key) as Total_customer
From (
	select
		customer_key,
		Customer_spending,
		Lifespan,
		CASE
			WHEN Customer_spending > 5000 AND Lifespan >= 12 THEN 'vip'
			WHEN Customer_spending < 5000 AND Lifespan >= 12 THEN 'REGULAR' 
			Else 'NEW'
		END Lifespan_segment
	from customer_segment
)t
Group by Lifespan_segment





