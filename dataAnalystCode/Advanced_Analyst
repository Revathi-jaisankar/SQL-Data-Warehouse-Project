--Performance Analysis

--Analyze the yearly Performance of products by comparing each products sales to both its average sales performance and the previous years sales.

---YOY Analysis

with Current_year_sales as (

	select 
		year(f.order_date) as Order_Year,
		p.product_name as Product_name,
		sum(f.sales_amount) as Current_year_Totalsales
	From gold.fact_sales f
	left Join gold.dim_products p
		on f.product_key = p.prd_key
	where f.order_date Is NOT NULL
	group by year(f.order_date), p.product_name
	
)
Select
	*,
	Avg(Current_year_Totalsales) Over(Partition by Product_name) as Avg_sales,
	Current_year_Totalsales- Avg(Current_year_Totalsales) Over(Partition by Product_name) as diff_avg,

	Case
		when Current_year_Totalsales - Avg(Current_year_Totalsales) Over(Partition by Product_name) > 0 then 'Above Average'
		when Current_year_Totalsales - Avg(Current_year_Totalsales) Over(Partition by Product_name) < 0 then 'Below Average'
		Else 'Avg'
	End Avg_change,
lag(Current_year_Totalsales) over(partition by Product_name order by Order_Year) as PreviousYear_sales,
Current_year_Totalsales - lag(Current_year_Totalsales) over(partition by Product_name order by Order_Year) as Diff_Py,
Case
		when Current_year_Totalsales - lag(Current_year_Totalsales) over(partition by Product_name order by Order_Year) > 0 then 'Increase'
		when Current_year_Totalsales - lag(Current_year_Totalsales) over(partition by Product_name order by Order_Year) < 0 then 'decrease'
		Else 'No Change'
	End PY_change
From Current_year_sales
order by  Product_name, Order_Year



-----------MOM Analysis-----------------

with Current_Month_sales as (
	select 
		DATETRUNC(Month, f.order_date) as Order_Month,
		p.product_name as Product_name,
		sum(f.sales_amount) as Current_Month_Totalsales
	From gold.fact_sales f
	left Join gold.dim_products p
		on f.product_key = p.prd_key
	where f.order_date Is NOT NULL
	group by DATETRUNC(Month, f.order_date), p.product_name
	
)
Select
	Order_Month,
	Product_name,
	Current_Month_Totalsales,
	Avg(Current_Month_Totalsales) Over(Partition by Product_name) as Avg_sales,
	Current_Month_Totalsales- Avg(Current_Month_Totalsales) Over(Partition by Product_name) as diff_avg,

	Case
		when Current_Month_Totalsales - Avg(Current_Month_Totalsales) Over(Partition by Product_name) > 0 then 'Above Average'
		when Current_Month_Totalsales - Avg(Current_Month_Totalsales) Over(Partition by Product_name) < 0 then 'Below Average'
		Else 'Avg'
	End Avg_change,
lag(Current_Month_Totalsales) over(partition by Product_name order by Order_Month) as PreviousYear_sales,
Current_Month_Totalsales - lag(Current_Month_Totalsales) over(partition by Product_name order by Order_Month) as Diff_Py,
Case
		when Current_Month_Totalsales - lag(Current_Month_Totalsales) over(partition by Product_name order by Order_Month) > 0 then 'Increase'
		when Current_Month_Totalsales - lag(Current_Month_Totalsales) over(partition by Product_name order by Order_Month) < 0 then 'decrease'
		Else 'No Change'
	End PY_change
From Current_Month_sales
order by  Product_name, Order_Month

