-- To convert the Date column int data type into date datatype before you have to check any negative in this column
-- Negative numbers or zeros cant be cast to a date
--Productures
-- step 1: 
Select
sls_order_dt
From silver.crm_sales_details
where sls_order_dt <= 0;

-- step 2:
Select
NULLIF(sls_order_dt, 0) sls_order_dt
From silver.crm_sales_details
where sls_order_dt <= 0

-- step 3: In the scenario, the length of the date must be 8

Select
NULLIF(sls_order_dt, 0) sls_order_dt
From silver.crm_sales_details
where sls_order_dt <= 0 or LEN(sls_order_dt) != 8

-- Step 4: To check for outliers by validating the boundaries of the data range

Select
NULLIF(sls_order_dt, 0) sls_order_dt
From silver.crm_sales_details
where sls_order_dt >20500101 or sls_order_dt < 19000101 --outside boundary

